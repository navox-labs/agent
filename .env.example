# === LLM Providers ===
OPENAI_API_KEY=sk-your-openai-key-here

# === Agent Settings ===
DEFAULT_LLM=openai
LOG_LEVEL=INFO

# === Email (Gmail IMAP/SMTP) ===
# To get an App Password: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# === Google Calendar (OAuth2) ===
# 1. Go to https://console.cloud.google.com/ and create a project
# 2. Enable "Google Calendar API"
# 3. Create OAuth Desktop credentials → download JSON
# 4. Save JSON as data/google_credentials.json
# 5. Run: python scripts/setup_google_oauth.py
GOOGLE_CREDENTIALS_PATH=data/google_credentials.json
GOOGLE_TOKEN_PATH=data/google_token.json

# === LinkedIn Session (Phase 8) ===
# Directory for persistent browser session data (cookies, localStorage)
# To set up: python scripts/setup_linkedin_session.py
LINKEDIN_SESSION_DIR=data/linkedin_session

# === Telegram Bot (Phase 13) ===
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_RATE_LIMIT=20
TELEGRAM_MAX_USERS_CACHED=100
